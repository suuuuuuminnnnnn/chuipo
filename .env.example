# Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_application_client_id
OWNER_DISCORD_ID=your_discord_user_id
ALERT_CHANNEL_ID=your_discord_channel_id

# Wanted (선택 - 서버 환경에서 headless 자동 로그인 시 필요)
# 없으면 /login 커맨드로 Discord에서 직접 로그인
WANTED_EMAIL=
WANTED_PASSWORD=

# Cron (optional)
CRON_APPLIED_SCHEDULE=*/30 * * * *
CRON_JOBS_SCHEDULE=0 */2 * * *

# Scoring thresholds (optional)
SCORE_THRESHOLD_HIGH=5
SCORE_THRESHOLD_LOW=-2
