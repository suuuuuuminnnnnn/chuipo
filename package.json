{
  "name": "chuipo",
  "version": "1.0.0",
  "description": "Wanted 채용 플랫폼 연동 Discord 봇 - 지원 현황 추적 & 공고 점수화",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "wanted:login": "tsx src/wanted/login.ts",
    "register-commands": "tsx src/register.ts",
    "typeorm": "tsx ./node_modules/typeorm/cli.js",
    "migration:run": "npm run typeorm -- migration:run -d src/db/datasource.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/db/datasource.ts",
    "migration:generate": "npm run typeorm -- migration:generate src/db/migrations/Migration -d src/db/datasource.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/typeorm": "^11.0.1",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^11.7.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "playwright": "^1.49.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.28",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
